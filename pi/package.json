{
  "name": "pi-stuff",
  "version": "0.1.0",
  "private": true,
  "description": "Personal pi coding agent extensions, skills, and themes",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "pi-theme"
  ],
  "pi": {
    "extensions": [
      "./pi-extensions",
      "./skills/victoria-metrics/extension",
      "./skills/opensearch/extension"
    ],
    "skills": [
      "./skills"
    ],
    "themes": [
      "./pi-theme"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "dependencies": {
    "duck-duck-scrape": "^2.2.7"
  }
}
